# ─── Correo para recuperación de contraseña ───────────────────────────────────
# Configurar con los datos del servidor SMTP corporativo
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=tu_correo@gmail.com
MAIL_FROM_NAME="AI Call Sync"
# Tiempo de expiración del enlace de recuperación (en minutos)
PASSWORD_RESET_EXPIRE=60
