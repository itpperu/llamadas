APP_NAME=GrabacionLlamada
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://llamadas.innovationtechnologyperu.com
APP_TIMEZONE=America/Lima

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=llamadas_db
DB_USERNAME=llamadas_user
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO

BROADCAST_CONNECTION=log
CACHE_STORE=file
CACHE_PREFIX=
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

AI_WORKER_URL=http://host.docker.internal:8001/process-call

# ── Correo para recuperación de contraseña ────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="AI Call Sync"
PASSWORD_RESET_EXPIRE=60
